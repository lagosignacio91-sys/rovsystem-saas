rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers de rol ----
    function signedIn() {
      return request.auth != null;
    }
    function rol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }
    function isAdmin()      { return signedIn() && rol() == 'admin'; }
    function isSupervisor() { return signedIn() && rol() == 'supervisor'; }  // el "taller"
    function isOperador()   { return signedIn() && rol() == 'operador'; }
    function isOwner()      { return signedIn() && rol() == 'owner'; }
    function isVentas()     { return signedIn() && rol() == 'ventas'; }
    function isApertura()   { return signedIn() && rol() == 'apertura'; }  // equipo que abre centros nuevos (team08)
    function rolValido(r) { return r in ['operador', 'supervisor', 'admin', 'owner', 'ventas', 'apertura']; }

    // Usuario "aprovisionado": autenticado Y con un perfil en /usuarios creado por
    // un admin (create es solo-admin). Cierra el hueco de S-01: una cuenta huérfana
    // de auto-registro cumple signedIn() pero NO tiene perfil, así que no debe leer
    // nada. El gate fuerte es la EXISTENCIA del perfil; el `&&` corta antes de llamar
    // a rol() si no existe. No se exige estado=='activo': ese campo arranca en
    // 'pendiente' al crear el usuario y hoy es auto-editable (ver S-10), no sirve de
    // frontera de confianza; se abordará por separado.
    function aprovisionado() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && rolValido(rol());
    }

    // ---- Usuarios ----
    // El roster lo leen varias vistas (mapa, centros, operadores).
    // Self puede actualizar su perfil (ej: passwordCambiado) PERO no su rol ni teamId
    // (evita auto-escalar privilegios). Crear/borrar solo admin.
    match /usuarios/{uid} {
      // PII (RUT, teléfono, correos): solo admin, taller y el propio usuario.
      allow read:   if isAdmin() || isSupervisor() || isOwner() || request.auth.uid == uid;
      allow create: if isAdmin() && rolValido(request.resource.data.rol);
      allow delete: if isAdmin();
      // Admin edita todo (con rol válido). El propio usuario solo campos seguros:
      // nunca rol, teamId ni empresaId (evita auto-escalar o cambiarse de empresa).
      allow update: if (isAdmin() && rolValido(request.resource.data.rol))
        || (request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['nombre', 'telefono', 'foto', 'passwordCambiado', 'estado', 'updatedAt', 'updatedBy', 'aceptoTerminos', 'correoPersonal']));
    }

    // ---- Kit de team (apertura) ----
    // El equipamiento del equipo de apertura (ROV, inventario, bitácora, roster,
    // entregas) vive en teams/team08/... porque VIAJA con el equipo, no pertenece
    // a ningún centro. Lo lee cualquier usuario aprovisionado; lo escribe el admin
    // o el propio usuario de apertura de ESE team (aislamiento por team, como S-02).
    match /teams/{teamId} {
      allow read: if aprovisionado();
      allow write: if isAdmin();
      match /{document=**} {
        allow read:  if aprovisionado();
        allow write: if isAdmin()
          || (isApertura()
              && teamId == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      }
    }

    // ---- Catálogos: cualquiera lee, solo admin escribe ----
    match /empresas/{id} {
      allow read:  if aprovisionado();
      allow write: if isAdmin() || isOwner();
    }
    match /config/{doc} {
      allow read:  if aprovisionado();
      allow write: if isAdmin();
    }

    // ---- Centros ----
    match /centros/{centroId} {
      allow read:          if aprovisionado();
      // Admin crea cualquier centro. Apertura crea SOLO centros marcados como suyos
      // (teamAsignado == 'team08'): así abre centros nuevos sin poder asignarlos a
      // otro team.
      allow create: if isAdmin()
        || (isApertura() && request.resource.data.teamAsignado == 'team08');
      allow delete: if isAdmin();
      // El doc del centro solo lo edita el admin, EXCEPTO:
      //  - `estado`, que se recalcula al cambiar stock: el taller, o el operador de ESE team.
      //  - "Cerrar apertura": apertura suelta SU centro (team08 → null) tocando solo
      //    teamAsignado/estadoCiclo; el centro queda registrado para su team definitivo.
      allow update: if isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
            && (isSupervisor()
                || (isOperador()
                    && resource.data.teamAsignado == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId)))
        || (isApertura()
            && resource.data.teamAsignado == 'team08'
            && request.resource.data.teamAsignado == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamAsignado', 'estadoCiclo']));

      // Entregas de turno: handoff entre operadores del MISMO team; admin y taller también.
      match /entregas/{entregaId} {
        allow read, create, update, delete: if isAdmin() || isSupervisor()
          || (isOperador()
              && get(/databases/$(database)/documents/centros/$(centroId)).data.teamAsignado
                 == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      }

      // Config por centro (lista de ítems del wizard): admin y taller escriben; operador solo lee.
      match /config/{doc} {
        allow read:  if aprovisionado();
        allow write: if isAdmin() || isSupervisor();
      }

      // Equipos ROV: solo admin y operador editan. El taller (supervisor) NO edita; sí lee fallas.
      // El operador solo edita equipos de centros de SU team (anti cross-tenant, S-02),
      // mismo patrón que datos/ y despachos — antes cualquier operador podía escribir
      // los equipos/fallas de centros de otros teams.
      match /equipos/{doc} {
        allow read:  if aprovisionado();
        allow write: if isAdmin()
          || (isOperador()
              && get(/databases/$(database)/documents/centros/$(centroId)).data.teamAsignado
                 == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      }

      // Datos operativos del centro:
      //  - estucheHerramientas/cajaHerramientas/operadores: admin, taller y operador
      //  - bitacora: SOLO operador escribe (admin y taller solo leen)
      match /datos/{doc} {
        // La bitácora solo la lee el operador si es de SU propio team (anti cross-tenant).
        // El taller (supervisor) no debe ver bitácoras diarias, ni siquiera vía lectura directa.
        // estucheHerramientas/cajaHerramientas/operadores siguen abiertas a cualquier autenticado
        // (ej. popup de contacto de centros ajenos en el Mapa).
        allow read:  if aprovisionado()
          && (doc != 'bitacora'
              || (!isOperador() && !isSupervisor())
              || (isOperador()
                  && get(/databases/$(database)/documents/centros/$(centroId)).data.teamAsignado
                     == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId));
        // El operador solo escribe en centros de SU team (anti cross-tenant).
        allow write: if (isAdmin()      && doc in ['estucheHerramientas', 'cajaHerramientas', 'operadores'])
          || (isSupervisor() && doc in ['estucheHerramientas', 'cajaHerramientas', 'operadores'])
          || (isOperador()   && doc in ['estucheHerramientas', 'cajaHerramientas', 'operadores', 'bitacora']
              && get(/databases/$(database)/documents/centros/$(centroId)).data.teamAsignado
                 == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      }
    }

    // ---- Despachos ----
    // Crear/enviar: admin y taller. Confirmar recepción (update): también el operador. Borrar: admin y taller.
    match /despachos/{id} {
      // El operador solo lee despachos de SU propio team (anti cross-tenant).
      // LV-02: se usa resource.data.get('teamAsignado','') en vez de acceso directo;
      // el acceso directo lanzaba "Property teamAsignado is undefined" al evaluar la
      // regla en consultas `list` (analisis estatico / docs sin el campo), rompiendo
      // el listener. get(...,'') es fail-closed: '' no coincide con ningún teamId real.
      allow read:          if aprovisionado()
        && (!isOperador() || resource.data.get('teamAsignado', '')
              == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      allow create:        if isAdmin() || isSupervisor();
      // El operador solo confirma recepción (campos acotados) y SOLO de su propio team.
      // `items` se incluye para que pueda marcar sus ítems como recibidos (ciclo "falta →
      // despacho"), pero `items.size()` sin cambios evita que agregue/quite ítems del array.
      allow update:        if isAdmin() || isSupervisor()
        || (isOperador()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['estado', 'observacion', 'recibidoEn', 'recibidoPor', 'historial', 'stockAplicado', 'items'])
            && request.resource.data.items.size() == resource.data.items.size()
            // S-07: validación de tipos — el operador no puede inyectar valores
            // corruptos (no-string) en estos campos vía SDK directo. get(...,'')
            // deja pasar el caso en que el campo no viene en el update.
            && request.resource.data.estado is string
            && request.resource.data.get('observacion', '') is string
            && request.resource.data.get('recibidoPor', '') is string
            && resource.data.teamAsignado
               == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);
      allow delete:        if isAdmin() || isSupervisor();
    }

    // ---- Tickets de equipo (falla -> baja -> reemplazo) ----
    // Independiente de `despachos`. Admin y taller controlan el ciclo completo
    // (crear, marcar reemplazo enviado, borrar). El operador solo hace dos
    // transiciones puntuales de SU propio team, con campos acotados por paso.
    match /equipoTickets/{id} {
      // LV-02: get('teamAsignado','') evita el error de evaluación en consultas list.
      allow read: if aprovisionado()
        && (!isOperador() || resource.data.get('teamAsignado', '')
              == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId);

      allow create: if isAdmin() || isSupervisor();

      allow update: if isAdmin() || isSupervisor()
        || (isOperador()
            && resource.data.teamAsignado
                 == get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.teamId
            && (
                 (resource.data.estado == 'solicitado'
                   && request.resource.data.estado == 'despachado_taller'
                   && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['estado', 'despachadoTallerEn', 'despachadoTallerPor', 'historial']))
              || (resource.data.estado == 'reemplazo_enviado'
                   && request.resource.data.estado == 'recibido'
                   && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['estado', 'recibidoEn', 'recibidoPor', 'recepcionObservacion', 'historial']))
               ));

      allow delete: if isAdmin() || isSupervisor();
    }

    // ---- Panel HyperionX Olimpo ----
    // Owner: acceso total. Ventas: solo lectura en clientes/pagos/productos + cartera completa.
    match /hxOlimpo/{doc} {
      allow read:  if isOwner() || isVentas();
      allow write: if isOwner();
    }
    match /hxPagos/{doc} {
      allow read:  if isOwner() || isVentas();
      allow write: if isOwner();
    }
    match /hxGastos/{doc} {
      allow read, write: if isOwner();
    }
    match /hxProductos/{doc} {
      allow read:  if isOwner() || isVentas();
      allow write: if isOwner();
    }
    match /hxClientes/{doc=**} {
      allow read:  if isOwner() || isVentas();
      allow write: if isOwner();
    }
    match /hxProspectos/{doc} {
      allow read, write: if isOwner() || isVentas();
      // Tracking anónimo de visitas (sin sesión). S-05: antes permitía escribir
      // `visitas`/`ultimaVisita` con CUALQUIER valor/estructura y sin límite. Ahora
      // solo se acepta un incremento de exactamente +1 en `visitas` (int) y un
      // `ultimaVisita` timestamp; get('visitas', 0) cubre el doc sin el campo aún.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['visitas', 'ultimaVisita'])
                     && request.resource.data.visitas is int
                     && request.resource.data.visitas == resource.data.get('visitas', 0) + 1
                     && request.resource.data.ultimaVisita is timestamp;
    }

    // ---- Centros: owner puede leer para métricas ----
    // (la regla principal de centros ya cubre read: if signedIn(); isOwner implica signedIn)

    // ---- Bodega Central (taller del supervisor) ----
    // Leer: admin y supervisor. Escribir: solo supervisor.
    match /bodegaCentral/{document=**} {
      allow read:  if isAdmin() || isSupervisor();
      allow write: if isSupervisor();
    }
  }
}
