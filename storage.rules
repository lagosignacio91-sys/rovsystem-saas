rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de inspección de entregas de turno.
    // Delete habilitado para auth: la función borrarFotosEntrega() lo necesita para
    // limpiar fotos de entregas anteriores al crear una nueva (fire-and-forget).
    // Trade-off aceptado: app invite-only con usuarios de confianza y paths con ID no predecible.
    // Mejora futura: incluir uid del operador en el path y restringir delete por uid.
    match /entregas/{centroId}/{entregaId}/{archivo} {
      allow read, write, delete: if request.auth != null;
    }

    // Resto: denegado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
