rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de inspección de entregas de turno.
    // Cualquier usuario autenticado puede leer, subir y borrar (las entregas
    // anteriores se eliminan automáticamente al crear una nueva).
    match /entregas/{centroId}/{entregaId}/{archivo} {
      allow read, write, delete: if request.auth != null;
    }

    // Resto: denegado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
