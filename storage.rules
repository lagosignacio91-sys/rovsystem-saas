rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de entregas de turno.
    // Write/delete: solo usuario que subió el archivo (metadata.uploadedBy) o admin.
    match /entregas/{centroId}/{entregaId}/{archivo} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (resource.metadata['uploadedBy'] == request.auth.uid
            || request.auth.token.email.matches('.*@hyperionx\\.tech'));
    }

    // Fotos de despacho.
    match /despachos/{despachoId}/{archivo} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (resource.metadata['uploadedBy'] == request.auth.uid
            || request.auth.token.email.matches('.*@hyperionx\\.tech'));
    }

    // Fotos de operador.
    match /operadores/{centroId}/{archivo} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (resource.metadata['uploadedBy'] == request.auth.uid
            || request.auth.token.email.matches('.*@hyperionx\\.tech'));
    }

    // Documentos Olimpo (hxDocs).
    match /hxDocs/{archivo} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null
        && (resource.metadata['uploadedBy'] == request.auth.uid
            || request.auth.token.email.matches('.*@hyperionx\\.tech'));
    }

    // Resto: denegado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
